# Copia este archivo a .env y completa los valores.
# NUNCA subas el .env real a git (ya está en .gitignore).

# Puerto TCP del microservicio de auth
AUTH_SERVICE_PORT=4001

# Conexión a la base de datos (Prisma)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secretos JWT — deben ser distintos entre sí y de al menos 32 caracteres
# aleatorios. Genera cada uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Duración de los tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
