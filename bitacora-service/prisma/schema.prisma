generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bitacora {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  destino       String
  destinoLat    Float    @map("destino_lat")
  destinoLng    Float    @map("destino_lng")
  texto         String
  temperatura   Float?
  humedad       Float?
  precipitacion Float?
  sincronizada  Boolean  @default(false)
  creadaEn      DateTime @default(now()) @map("creada_en")
  sincronizadaEn DateTime? @map("sincronizada_en")

  @@map("bitacoras")
}

model Parcela {
  id        String   @id @default(uuid())
  nombre    String
  ubicacion String
  hectareas Float
  cultivo   String   @default("cacao")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  climas Clima[]

  @@map("parcelas")
}

model Clima {
  id            String   @id @default(uuid())
  parcelaId     String   @map("parcela_id")
  temperatura   Float
  humedad       Float
  precipitacion Float?
  nivelRiesgo   String   @default("BAJO")
  fecha         DateTime @default(now())

  parcela Parcela @relation(fields: [parcelaId], references: [id], onDelete: Cascade)

  @@map("climas")
}